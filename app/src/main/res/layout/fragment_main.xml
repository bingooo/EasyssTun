<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="14dp"
    android:orientation="vertical">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/service_card"
        style="@style/mCard">

        <LinearLayout style="@style/Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/service_icon"
                    style="@style/CardIcon"
                    android:src="@drawable/ic_launcher_foreground_big" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:duplicateParentState="true"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/service_title"
                        style="@style/CardTitle"
                        android:text="@string/service_running" />

                    <TextView
                        android:id="@+id/service_summary"
                        style="@style/CardSummary"
                        android:text="@string/easyss_need_config" />

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/service_setting"
                    style="@style/CardButton"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="12dp"
                    android:backgroundTint="@color/button_enable"
                    android:text="@string/easyss_configure"
                    app:icon="@drawable/ic_settings_outline_24dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/service_button"
                    style="@style/CardButton"
                    android:layout_marginTop="12dp"
                    android:text="@string/service_enable"
                    app:icon="@drawable/ic_outline_play_arrow_24" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        style="@style/mCard"
        android:layout_marginTop="10dp">

        <LinearLayout
            style="@style/Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/applist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@android:id/icon"
                    style="@style/CardIcon"
                    android:src="@drawable/playlist_remove_24px" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:duplicateParentState="true"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/text1"
                        style="@style/CardTitle"
                        android:text="已经跳过的应用" />

                    <TextView
                        android:id="@android:id/text2"
                        style="@style/CardSummary"
                        android:text="@string/choose_app_to_bypass" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layoutDirection="rtl"
                android:text="@string/route_desc"
                android:textAlignment="viewEnd" />
        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>


    <com.google.android.material.card.MaterialCardView
        style="@style/mCard"
        android:layout_marginTop="10dp">

        <LinearLayout
            android:id="@+id/speed_test"
            style="@style/Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/speed_test_icon"
                style="@style/CardIcon"
                android:src="@drawable/ic_outline_info_24" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:duplicateParentState="true"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/speed_result"
                    style="@style/CardTitle"
                    android:text="@string/speedtest_placeholder" />

                <TextView
                    style="@style/CardSummary"
                    android:text="@string/speedtest_summary" />
            </LinearLayout>
        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>