<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Enable Switch Card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/mCard"
            android:layout_marginBottom="12dp">

            <LinearLayout
                style="@style/Card"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/CardTitle"
                        android:text="启用 Tailscale" />

                    <TextView
                        style="@style/CardSummary"
                        android:text="开启后, Tailnet 流量将通过内嵌 tsnet 节点分流" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_tailscale_enable"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Status Card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/mCard"
            android:layout_marginBottom="12dp">

            <LinearLayout
                style="@style/Card"
                android:orientation="vertical">

                <TextView
                    style="@style/CardTitle"
                    android:text="Tailscale 连接状态" />

                <TextView
                    android:id="@+id/tv_tailscale_state"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Status: Stopped"
                    android:textStyle="bold"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tv_tailscale_ips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="IP: --"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_magic_dns"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="MagicDNS: --"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_refresh_status"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="刷新状态" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Configuration Card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/mCard">

            <LinearLayout
                style="@style/Card"
                android:orientation="vertical">

                <TextView
                    style="@style/CardTitle"
                    android:text="Tailscale 节点配置"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="Auth Key (授权密钥)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_auth_key"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="Control Server URL (Control 节点地址)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_control_url"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Device Hostname (节点设备名)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_hostname"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save_config"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="保存配置" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
